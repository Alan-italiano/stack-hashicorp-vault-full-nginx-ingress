        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "multi": true,
        "name": "pod",
        "query": "label_values(up{namespace=\"$namespace\"}, pod)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Vault Telemetry - Replication, Latency, Health, Storage",
  "version": 1,
  "weekStart": ""
}
